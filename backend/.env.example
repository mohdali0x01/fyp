# Server
PORT=5000
NODE_ENV=development

# Database - PostgreSQL (running in Docker on port 5433)
DATABASE_URL="postgresql://appuser:YOUR_PASSWORD@localhost:5433/appdb"

# JWT
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=1h

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
