# ──────────────────────────────────────────────────────────────────────────────
# AidLedger Flask Backend — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to git.
# ──────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000
FLASK_ENV=development
FRONTEND_URL=http://localhost:3001

# Database — PostgreSQL (running in Docker on port 5433)
DATABASE_URL="postgresql://appuser:YOUR_PASSWORD@localhost:5433/appdb"

# JWT — use a long random string (64+ chars) in production
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=3600

# Rate Limiting (15 minute window, 100 requests max)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Blockchain (Besu) Configuration
RPC_URL="http://127.0.0.1:8545"
AIDLEDGER_GOV_ADDRESS="your_gov_contract_address"
AID_REGISTRY_ADDRESS="your_registry_contract_address"
AIDLEDGER_PRIVATE_KEY="your_aidledger_wallet_private_key"

# Data Files
CITIES_FILE_PATH="/mnt/e/FYP/Data/Cities.txt"
