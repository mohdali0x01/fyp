generator client {
  provider                    = "prisma-client-py"
  interface                   = "sync"
  recursive_type_depth        = 5
  enable_experimental_decimal = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model card_issue {
  card_id             Int            @id @default(autoincrement())
  eligible_id         Int            @unique
  cnic                String         @unique @db.VarChar(50)
  virtual_card_number String         @unique @db.VarChar(16)
  card_status         String?        @default("ACTIVE") @db.VarChar(50)
  issue_date          DateTime?      @default(dbgenerated("CURRENT_DATE")) @db.Date
  expiry_date         DateTime       @db.Date
  registration        registration   @relation(fields: [cnic], references: [cnic], onDelete: NoAction, onUpdate: NoAction)
  eligible            eligible       @relation(fields: [eligible_id], references: [eligible_id], onDelete: NoAction, onUpdate: NoAction)
  transactions        transactions[]
}

model eligible {
  eligible_id              Int          @id @default(autoincrement())
  cnic                     String       @unique @db.VarChar(50)
  blockchain_approval_hash String
  card_issued              Boolean?     @default(false)
  approved_at              DateTime?    @default(now()) @db.Timestamp(6)
  card_issue               card_issue?
  registration             registration @relation(fields: [cnic], references: [cnic], onDelete: NoAction, onUpdate: NoAction)
}

model family_tree {
  family_id           String   @id @db.VarChar(50)
  head_of_family_cnic String?  @db.VarChar(50)
  family_member_cnics String[] @db.VarChar(50)
  total_members       Int?
}

model kyc_master {
  cnic                 String   @id @db.VarChar(50)
  full_name            String?  @db.VarChar(150)
  gender               String?  @db.VarChar(10)
  phone                String?  @db.VarChar(50)
  address              String?
  salary               Decimal? @db.Decimal(15, 2)
  govt_job             Boolean? @default(false)
  utility_bill_amount  Decimal? @db.Decimal(15, 2)
  monthly_expense      Decimal? @db.Decimal(15, 2)
  family_members_count Int?
  marital_status       String?  @db.VarChar(50)
  family_id            String?  @db.VarChar(50)
}

model notifications {
  notification_id   Int          @id @default(autoincrement())
  cnic              String       @db.VarChar(50)
  message_text_urdu String
  status            String?      @default("PENDING") @db.VarChar(50)
  created_at        DateTime?    @default(now()) @db.Timestamp(6)
  sent_at           DateTime?    @db.Timestamp(6)
  registration      registration @relation(fields: [cnic], references: [cnic], onDelete: NoAction, onUpdate: NoAction)
}

model policies {
  policy_id          Int       @id @default(autoincrement())
  
  // Basic constraints
  max_salary_allowed Decimal   @db.Decimal(10, 2)
  max_family_members Int

  // Blockchain Synced GRC Rules
  urban_pmt_limit     Decimal   @db.Decimal(5, 2)
  rural_pmt_limit     Decimal   @db.Decimal(5, 2)
  max_cash_limit      Decimal   @db.Decimal(10, 2)
  max_quarterly_limit Decimal   @db.Decimal(10, 2)
  global_budget       Decimal   @db.Decimal(15, 2)

  is_active          Boolean?  @default(false)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)
}

model registration {
  registration_id Int             @id @default(autoincrement())
  cnic            String          @unique @db.VarChar(50)
  full_name       String?         @db.VarChar(150)
  address         String?
  city            String?         @db.VarChar(100)
  pipeline_status String?         @default("PENDING") @db.VarChar(50)
  created_at      DateTime?       @default(now()) @db.Timestamp(6)
  user_id         Int?
  card_issue      card_issue?
  eligible        eligible?
  notifications   notifications[]
  users           users?          @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_registration_users")
}

model transactions {
  transaction_id     Int        @id @default(autoincrement())
  card_id            Int
  vendor_user_id     Int
  transaction_type   String     @db.VarChar(50)
  amount             Decimal    @db.Decimal(15, 2)
  blockchain_tx_hash String
  status             String?    @default("COMPLETED") @db.VarChar(50)
  timestamp          DateTime?  @default(now()) @db.Timestamp(6)
  card_issue         card_issue @relation(fields: [card_id], references: [card_id], onDelete: NoAction, onUpdate: NoAction)
  users              users      @relation(fields: [vendor_user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  user_id       Int            @id @default(autoincrement())
  username      String         @unique @db.VarChar(100)
  phone_number  String         @unique @db.VarChar(255)
  password_hash String
  role          String         @db.VarChar(50)
  registration  registration[]
  transactions  transactions[]
}
